  <string name="settings_resolution_scale">Resolution Scale</string>
  <string name="settings_resolution_scale_desc">Internal rendering resolution multiplier. Applied on next game launch.</string>
  <string name="settings_filtering">Texture Filtering</string>
  <string name="settings_aspect_ratio">Aspect Ratio</string>
  <string name="settings_unlock_framerate">Unlock frame rate</string>
  <string name="settings_unlock_framerate_desc">Prevents frame rate from locking to 30 FPS when the device can\'t sustain 60 FPS. May affect game speed.</string>
  <string name="settings_fp_safe">Native Floats (Safe)</string>
  <string name="settings_fp_safe_desc">Use native ARM64 double-precision for x87 FPU arithmetic. Keeps legacy 80-bit storage. Moderate speedup with good compatibility.</string>

  <string name="settings_fp_jit">Native Floats (JIT)</string>
  <string name="settings_fp_jit_desc">Full JIT-level FP optimization: native 64-bit storage + inline FP instructions. Best performance but may reduce accuracy. Applied on next game launch.</string>

  <string name="settings_fast_fences">Fast fences (reduce GPU stalls)</string>
  <string name="settings_fast_fences_desc">Defer GPU fence waits for buffer-space and vertex-dirty flushes. Significantly reduces frame time but may cause geometry popping or flickering.</string>

  <string name="settings_skip_occlusion">Skip occlusion queries (reduce render passes)</string>
  <string name="settings_skip_occlusion_desc">Skip GPU visibility testing queries. Dramatically reduces render pass count on tiled GPUs. Games may render extra geometry but visuals are not corrupted.</string>

  <string name="settings_texture_cache">Texture cache size</string>
  <string name="settings_texture_cache_desc">Number of texture cache entries. 0 = auto (based on GPU memory). Increase for open-world games with texture pop-in (1024–2048 recommended). Requires game restart.</string>

  <string name="settings_draw_reorder">Draw reordering (reduce pipeline switches)</string>
  <string name="settings_draw_reorder_desc">Reorder safe draw calls within small windows to reduce GPU pipeline switches. Improves performance on tiled GPUs (Adreno). May cause minor visual artifacts in some titles.</string>

  <string name="settings_draw_merge">Draw merging (batch draw calls)</string>
  <string name="settings_draw_merge_desc">Merge consecutive compatible draw calls into fewer GPU submissions. Reduces driver overhead on tiled GPUs (Adreno). May introduce visual artifacts in some titles.</string>


  <string name="settings_async_compile">Async shader compilation</string>
  <string name="settings_async_compile_desc">Compile shaders in background to reduce stutter. May cause brief visual pop-in.</string>

  <string name="settings_frame_skip">Frame skip</string>
  <string name="settings_frame_skip_desc">Skip rendering when running behind to maintain game speed. May cause visible stuttering.</string>

  <string name="settings_submit_frames">Submit frame buffering</string>
  <string name="settings_submit_frames_desc">Number of GPU submission frames. Higher values increase parallelism but use more memory and add latency. Single = lowest memory, Triple = best throughput.</string>

  <string name="settings_tier1_threshold">Tier-1 recompilation threshold</string>
  <string name="settings_tier1_threshold_desc">How many times a code block must execute before it is recompiled with optimizations. Lower = more aggressive optimization (more CPU overhead). Higher = fewer optimizations (less overhead).</string>

  <string name="settings_validation_layers">Vulkan validation layers</string>
  <string name="settings_validation_layers_desc">Enable Vulkan validation for graphics debugging. Significant performance impact. Applied on next game launch.</string>

  <string name="settings_show_fps_desc">Display a frames-per-second counter during gameplay.</string>
  <string name="settings_skip_boot_anim_desc">Jump straight to the game, skipping the Xbox boot animation.</string>
